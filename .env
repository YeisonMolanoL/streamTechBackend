# Variables de entorno para desarrollo

# =====================================================
# BASE DE DATOS - USANDO POSTGRESQL
# =====================================================
DATABASE=streamtech
USERNAME=postgres
PASSWORD=postgres
HOST=localhost

# =====================================================
# SEGURIDAD JWT
# =====================================================
SECRET=tu_super_secret_key_muy_largo_para_jwt_aqui_123456789

# =====================================================
# ENCRIPTACIÓN (AES-256 necesita 32 bytes)
# =====================================================
ENCRYPTION_KEY=clave32bytesparaaes256encryptionkey

# =====================================================
# SPRING PROFILES
# =====================================================
SPRING_PROFILES_ACTIVE=dev

# =====================================================
# IMAP SETTINGS (opcional, valores por defecto)
# =====================================================
IMAP_TIMEOUT=10000
IMAP_POLLING_INTERVAL=500
IMAP_POLLING_TIMEOUT=30000
